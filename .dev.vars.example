# Copy this file to ".dev.vars" for local development with `wrangler dev`.
# These are read as server-side environment variables by the Worker.

# --- FMP (data) ---
FMP_API_KEY=your_fmp_api_key_here

# --- AI provider (OpenAI-compatible /chat/completions) ---
# Default provider = Perplexity (Sonar models only).
PERPLEXITY_API_KEY=your_perplexity_api_key_here
PERPLEXITY_MODEL=sonar

# To use GPT models (openai/gpt-5.5, openai/gpt-5.4-nano), switch the provider:
#   1) point the base URL at OpenRouter (or OpenAI)
#   2) put that provider's key in AI_API_KEY
# AI_BASE_URL=https://openrouter.ai/api/v1
# AI_API_KEY=your_openrouter_or_openai_key_here
