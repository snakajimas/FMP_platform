# Copy this file to ".dev.vars" for local development with `wrangler dev`.
# These are read as server-side environment variables by the Worker.

# --- FMP (market data) ---
FMP_API_KEY=your_fmp_api_key_here

# --- AI: Perplexity Agent API ---
# A single Perplexity key. The Agent API can route to openai/* models via the
# provider/model id (no OpenAI key needed).
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Default model (must be in the allowlist in worker/lib/models.ts)
PERPLEXITY_MODEL=openai/gpt-5.5
