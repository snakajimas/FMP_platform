# Copy this file to ".dev.vars" for local development with `wrangler pages dev`.
# These are read as server-side environment variables by Pages Functions.
FMP_API_KEY=your_fmp_api_key_here
PERPLEXITY_API_KEY=your_perplexity_api_key_here
# Optional override of the Perplexity model (default: sonar)
PERPLEXITY_MODEL=sonar
